{
  "name": "fasting-app-firebase-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "emulators:start": "firebase emulators:start --project demo-fasting-app --only auth,firestore",
    "test:rules": "firebase emulators:exec --project demo-fasting-app --only firestore,auth \"node --test firebase/firestore.rules.test.mjs\"",
    "test:rules:unit": "node --test firebase/firestore.rules.test.mjs"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "firebase": "12.15.0",
    "firebase-tools": "15.22.4"
  }
}
